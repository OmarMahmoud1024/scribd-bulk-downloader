# Copy this file to .env and fill in real credentials.
# Never commit the real .env file - it's already in .gitignore.

# Comma-separated pool of accounts, format: email:password,email:password,...
SCRIBD_ACCOUNT_POOL=account1@example.com:changeme1,account2@example.com:changeme2,account3@example.com:changeme3,account4@example.com:changeme4,account5@example.com:changeme5

# Optional: override the empirically-observed per-account daily download cap
SCRIBD_DAILY_LIMIT_PER_ACCOUNT=200
